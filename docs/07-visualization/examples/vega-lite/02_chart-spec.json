{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Monthly trend with 3 chart types",
  "data": {
    "values": [
      {
        "month": "Jan",
        "value": 100
      },
      {
        "month": "Feb",
        "value": 120
