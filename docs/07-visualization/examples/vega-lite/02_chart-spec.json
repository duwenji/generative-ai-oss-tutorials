      }
    },
    {
      "title": "Area",
      "width": 820,
      "height": 220,
      "mark": {
        "type": "area",
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "field": "month",
          "type": "ordinal",
          "title": "Month"
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "title": "Value"
        },
