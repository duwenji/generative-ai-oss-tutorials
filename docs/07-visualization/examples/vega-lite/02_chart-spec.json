          },
          {
            "field": "value",
            "type": "quantitative"
          }
        ]
      }
    },
    {
      "title": "Bar",
      "width": 820,
      "height": 220,
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "month",
          "type": "ordinal",
          "title": "Month"
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "title": "Value"
        },
        "tooltip": [
          {
            "field": "month",
            "type": "ordinal"
          },
          {
            "field": "value",
